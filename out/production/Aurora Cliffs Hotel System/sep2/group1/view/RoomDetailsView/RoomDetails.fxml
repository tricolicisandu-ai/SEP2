<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sep2.group1.view.RoomDetailsView.RoomDetailsController">
    <children>
        <Label alignment="CENTER" contentDisplay="CENTER" style="-fx-font-size: 30px; -fx-font-weight: bold;" text="Room Details" textAlignment="CENTER" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10;" VBox.vgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Check - In" />
                        <DatePicker fx:id="checkInPicker" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Check - Out" />
                        <DatePicker fx:id="checkOutPicker" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Guests" />
                        <ChoiceBox fx:id="numberOfGuestsPicker" prefWidth="50.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <Button fx:id="resetButton" alignment="CENTER" contentDisplay="CENTER" text="Reset" textAlignment="CENTER" onAction="#onReset">
                    <HBox.margin>
                        <Insets right="5.0" />
                    </HBox.margin>
                </Button>
                <Button fx:id="viewRoomsButton"  alignment="CENTER" contentDisplay="CENTER" onAction="#onViewRooms" text="View Rooms" textAlignment="CENTER">
                    <HBox.margin>
                        <Insets left="5.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="10.0" />

        <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIndex" prefWidth="75.0" text="#" />
                <TableColumn fx:id="colRoomNumber" prefWidth="132.0" text="Room Number" />
                <TableColumn fx:id="colRoomType" prefWidth="167.5" text="Room Type" />
                <TableColumn fx:id="colBeds" prefWidth="133.0" text="Number of Beds" />
                <TableColumn fx:id="colGuests" prefWidth="123.5" text="Guests" />
                <TableColumn fx:id="colPrice" prefWidth="153.0" text="Price" />
            </columns>
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER">
            <children>
                <Button fx:id="selectButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onSelect" prefWidth="80.0" text="Select" textAlignment="CENTER" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets bottom="10.0" />
                    </HBox.margin></Button>
                <Button text="Manager View" onAction="#onOpenManager"/>
            </children>
        </HBox>
    </children>
</VBox>
