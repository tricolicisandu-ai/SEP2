<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="0">
            <children>
                <Button mnemonicParsing="false" prefWidth="100.0" style="-fx-background-color: white;" text="Log Out" textFill="#00bcff">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>

                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Reservations" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="30.0" />
                    </font>
                </Label>

                <Region prefWidth="100.0" />
            </children>
            <VBox.margin>
                <Insets left="15.0" right="15.0" top="10.0" />
            </VBox.margin>
        </HBox>
        <HBox prefHeight="100.0" prefWidth="200.0">
            <children>
                <TextField promptText="Reservation Number" />
                <TextField promptText="Room Number">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </TextField>
                <TextField promptText="Email">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </TextField>
                <Button alignment="CENTER" mnemonicParsing="false" text="Search">
                    <HBox.margin>
                        <Insets left="100.0" />
                    </HBox.margin>
                </Button>
            </children>
            <VBox.margin>
                <Insets left="50.0" />
            </VBox.margin>
        </HBox>

        <TableView fx:id="roomsTable" prefHeight="398.0" prefWidth="780.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNumber" prefWidth="43.0" text="#" />
                <TableColumn fx:id="colRoomType" prefWidth="131.5" text="Reservation Number" />
                <TableColumn fx:id="colRoomNumber" prefWidth="110.0" text="Room Number" />
                <TableColumn fx:id="colBeds" prefWidth="135.0" text="Email" />
                <TableColumn fx:id="colGuests" prefWidth="88.5" text="Check - In" />
                <TableColumn fx:id="colPrice" prefWidth="89.0" text="Check - Out" />
                <TableColumn fx:id="colPrice1" prefWidth="125.5" text="Status" />
            </columns>
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="10.0">
            <children>
                <Button fx:id="selectButton1" mnemonicParsing="false" text="Cancel Reservation" />
                <Button fx:id="selectButton2" mnemonicParsing="false" text="Check-In" />
                <Button fx:id="selectButton11" mnemonicParsing="false" text="Check-Out" />
            </children>
            <VBox.margin>
                <Insets bottom="15.0" right="15.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
