<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sep2.group1.client.view.MaidView.MaidController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="0">
            <children>
                <Button fx:id="logOutButton" mnemonicParsing="false" onAction="#onLogOut" prefWidth="100.0" style="-fx-background-color: white;" text="Log Out" textFill="#00bcff">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>

                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Room Maintenance" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="30.0" />
                    </font>
                </Label>

                <Region prefWidth="100.0" />
            </children>
            <VBox.margin>
                <Insets left="15.0" right="15.0" top="10.0" />
            </VBox.margin>
        </HBox>
        <HBox prefHeight="100.0" prefWidth="200.0">
            <VBox.margin>
                <Insets left="50.0" />
            </VBox.margin>
        </HBox>

        <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colRoomNumber" prefWidth="203.5" text="Room Number" />
                <TableColumn fx:id="colRoomType" prefWidth="247.5" text="Room Type" />
                <TableColumn fx:id="colNumberOfBeds" prefWidth="157.5" text="Number of Beds" />
                <TableColumn fx:id="colEmail" text="Email"/>
                <TableColumn fx:id="colStatus" prefWidth="167.5" text="Status" />
            </columns>
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" prefHeight="50.0" spacing="10.0">
            <children>
                <Button fx:id="cleanButton" mnemonicParsing="false" onAction="#onClean" prefWidth="70.0" text="Clean" />
            </children>
            <VBox.margin>
                <Insets bottom="15.0" right="15.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
